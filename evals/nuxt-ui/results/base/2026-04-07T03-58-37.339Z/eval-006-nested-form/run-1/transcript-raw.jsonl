    <UInputNumber v-model=\"item.quantity\" :min=\"1\" class=\"w-full\" />\n                </UFormField>\n              </div>\n              <div class=\"col-span-3\">\n                <UFormField :name=\"`price`\">\n                  <UInputNumber v-model=\"item.price\" :min=\"0\" :step=\"0.01\" class=\"w-full\" />\n                </UFormField>\n              </div>\n              <div class=\"col-span-1 flex items-start pt-1\">\n                <UButton\n                  color=\"error\"\n                  variant=\"ghost\"\n                  icon=\"i-lucide-trash-2\"\n                  size=\"sm\"\n                  @click=\"removeItem(index)\"\n                />\n              </div>\n            </div>\n          </UForm>\n        </div>\n      </div>\n\n      <UButton\n        variant=\"outline\"\n        icon=\"i-lucide-plus\"\n        class=\"mb-6\"\n        @click=\"addItem\"\n      >\n        Add Item\n      </UButton>\n\n      <div class=\"border-t pt-4 mb-6\">\n        <div class=\"flex justify-end text-lg font-semibold\">\n          Total: ${{ total.toFixed(2) }}\n        </div>\n      </div>\n\n      <UButton type=\"submit\" color=\"primary\">Submit Invoice</UButton>\n    </UForm>\n\n    <div v-if=\"submitted\" class=\"mt-6 p-4 bg-gray-100 dark:bg-gray-800 rounded-lg\">\n      <h2 class=\"font-semibold mb-2\">Submitted Data:</h2>\n      <pre class=\"text-sm overflow-auto\">{{ JSON.stringify(submitted, null, 2) }}</pre>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\nimport { z } from 'zod'\n\nconst lineItemSchema = z.object({\n  description: z.string().min(1, 'Description is required'),\n  quantity: z.number().min(1, 'Quantity must be at least 1'),\n  price: z.number().min(0, 'Price must be non-negative'),\n})\n\nconst invoiceSchema = z.object({\n  customer: z.string().min(1, 'Customer is required'),\n  date: z.string().min(1, 'Date is required'),\n  items: z.array(lineItemSchema).min(1, 'At least one item is required'),\n})\n\ntype LineItem = z.infer<typeof lineItemSchema>\ntype InvoiceState = z.infer<typeof invoiceSchema>\n\nconst state = reactive<InvoiceState>({\n  customer: '',\n  date: '',\n  items: [{ description: '', quantity: 1, price: 0 }],\n})\n\nconst total = computed(() =>\n  state.items.reduce((sum, item) => sum + item.quantity * item.price, 0)\n)\n\nfunction addItem() {\n  state.items.push({ description: '', quantity: 1, price: 0 })\n}\n\nfunction removeItem(index: number) {\n  state.items.splice(index, 1)\n}\n\nconst submitted = ref<InvoiceState | null>(null)\n\nfunction onSubmit() {\n  console.log('Invoice submitted:', JSON.parse(JSON.stringify(state)))\n  submitted.value = JSON.parse(JSON.stringify(state))\n}\n</script>\n","structuredPatch":[{"oldStart":1,"oldLines":6,"newStart":1,"newLines":122,"lines":[" <template>","-  <div>","-    <h1>Invoice</h1>","-    <p>Build an invoice form with dynamic line items here.</p>","+  <div class=\"max-w-3xl mx-auto p-8\">","+    <h1 class=\"text-2xl font-bold mb-6\">Invoice</h1>","+","+    <UForm :schema=\"invoiceSchema\" :state=\"state\" @submit=\"onSubmit\">","+      <div class=\"grid grid-cols-2 gap-4 mb-6\">","+        <UFormField label=\"Customer\" name=\"customer\">","+          <UInput v-model=\"state.customer\" placeholder=\"Customer name\" class=\"w-full\" />","+        </UFormField>","+        <UFormField label=\"Date\" name=\"date\">","+          <UInput v-model=\"state.date\" type=\"date\" class=\"w-full\" />","+        </UFormField>","+      </div>","+","+      <div class=\"mb-4\">","+        <div class=\"grid grid-cols-12 gap-2 mb-2 text-sm font-medium text-gray-500 px-1\">","+          <div class=\"col-span-6\">Description</div>","+          <div class=\"col-span-2\">Quantity</div>","+          <div class=\"col-span-3\">Price</div>","+          <div class=\"col-span-1\"></div>","+        </div>","+","+        <div v-for=\"(item, index) in state.items\" :key=\"index\" class=\"mb-2\">","+          <UForm nested :name=\"`items