{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "repo": {
      "type": "string",
      "pattern": "^[^/]+\\/[^/]+$"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "license": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "packages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "ecosystem": {
                  "type": "string",
                  "enum": [
                    "npm",
                    "pypi",
                    "pub",
                    "go",
                    "crates",
                    "hex",
                    "nuget",
                    "maven"
                  ]
                },
                "name": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "ecosystem",
                "name"
              ],
              "additionalProperties": false
            },
            "minItems": 1
          },
          "sources": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "npm"
                    },
                    "package": {
                      "type": "string",
                      "minLength": 1
                    },
                    "path": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "package"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "github"
                    },
                    "repo": {
                      "type": "string",
                      "pattern": "^[^/]+\\/[^/]+$"
                    },
                    "branch": {
                      "type": "string"
                    },
                    "tag": {
                      "type": "string"
                    },
                    "path": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "repo"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "web"
                    },
                    "urls": {
                      "type": "array",
                      "items": {
                        "type": "string",
                        "format": "uri"
                      },
                      "minItems": 1
                    },
                    "maxDepth": {
                      "type": "integer",
                      "exclusiveMinimum": 0
                    },
                    "allowedPathPrefix": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "type",
                    "urls"
                  ],
                  "additionalProperties": false
                },
                {
                  "type": "object",
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "llms-txt"
                    },
                    "url": {
                      "type": "string",
                      "format": "uri"
                    }
                  },
                  "required": [
                    "type",
                    "url"
                  ],
                  "additionalProperties": false
                }
              ]
            },
            "minItems": 1
          }
        },
        "required": [
          "name",
          "aliases",
          "sources"
        ],
        "additionalProperties": false
      },
      "minItems": 1
    }
  },
  "required": [
    "name",
    "description",
    "repo",
    "packages"
  ],
  "additionalProperties": false
}
