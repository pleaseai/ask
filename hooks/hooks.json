{
  "description": "Suggest ask CLI commands when WebFetch targets GitHub or a known library docs site",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "WebFetch",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/fetch-hint.mjs\""
          }
        ]
      }
    ]
  }
}
